rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isWorker() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'worker';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isBookingOwner(bookingData) {
      return isAuthenticated() && (
        bookingData.customerId == request.auth.uid ||
        bookingData.userId == request.auth.uid
      );
    }

    function isAssignedWorker(bookingData) {
      return isWorker() && bookingData.washerId == request.auth.uid;
    }

    function bookingStatusRank(status) {
      return status == 'Assigned' ? 1
        : status == 'EnRoute' ? 2
        : status == 'Arrived' ? 3
        : status == 'Washing' ? 4
        : status == 'Completed' ? 5
        : 0;
    }

    function isWorkerBookingUpdate() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return changedKeys.hasOnly([
          'status', 'arrivedAt', 'startedExteriorPrepAt', 'interiorWorkAt',
          'qualityCheckAt', 'lastStatusAt', 'updatedAt'
        ])
        && request.resource.data.customerId == resource.data.customerId
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.washerId == resource.data.washerId
        && bookingStatusRank(request.resource.data.status) >= bookingStatusRank(resource.data.status)
        && request.resource.data.status in ['Assigned', 'EnRoute', 'Arrived', 'Washing', 'Completed'];
    }

    match /users/{userId} {
      function isBootstrapAdmin() {
        return request.auth.uid == userId
          && request.resource.data.email == 'admin@ecoshine.na'
          && request.resource.data.role == 'admin';
      }

      function isClientProfileUpdate() {
        let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
        return changedKeys.hasOnly([
            'name', 'displayName', 'phone', 'profilePicture', 'photoURL',
            'membershipTier', 'tier', 'theme', 'preferredTheme', 'updatedAt'
          ])
          && request.resource.data.role == resource.data.role
          && request.resource.data.email == resource.data.email
          && (
            !changedKeys.hasAny(['profilePicture'])
            || (
              request.resource.data.profilePicture is string
              && request.resource.data.profilePicture.size() < 900000
            )
          );
      }

      allow read: if isAdmin() || isOwner(userId) || isWorker();
      allow create: if isAuthenticated() && (
        (request.auth.uid == userId && request.resource.data.role == 'client') || isBootstrapAdmin()
      );
      allow update: if isAdmin() || (isOwner(userId) && isClientProfileUpdate());
      allow delete: if isAdmin();
    }

    match /washers/{washerId} {
      allow read: if isAdmin() || isOwner(washerId) || isWorker();
      allow create, update, delete: if isAdmin() || isOwner(washerId);
    }

    match /liveLocations/{washerId} {
      allow read: if isAdmin() || isOwner(washerId) || isWorker();
      allow create, update, delete: if isAdmin() || isOwner(washerId);
    }

    match /bookings/{bookingId} {
      allow read: if isAdmin() || isWorker() || isBookingOwner(resource.data);
      allow create: if isAuthenticated() && (
        request.resource.data.customerId == request.auth.uid || request.resource.data.userId == request.auth.uid
      );
      allow update: if isAdmin() || (
        isAssignedWorker(resource.data) && isWorkerBookingUpdate()
      ) || (
        isBookingOwner(resource.data) &&
        request.resource.data.status == 'Cancelled' &&
        request.resource.data.customerId == resource.data.customerId &&
        request.resource.data.washerId == resource.data.washerId
      );
      allow delete: if isAdmin();

      match /ratings/{ratingId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && (
          request.resource.data.reviewerId == request.auth.uid || request.resource.data.reviewerRole == 'customer' || request.resource.data.reviewerRole == 'worker'
        );
        allow update, delete: if isAdmin() || request.auth.uid == resource.data.reviewerId;
      }
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isAdmin();
      allow update, delete: if isAdmin() || isOwner(userId);
    }

    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
